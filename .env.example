# CrowdGIS serverless functions — set these in Vercel (Project → Settings → Environment Variables)

# GitHub repository holding the feature-request issues, e.g. "CrowdGIS/crowdgis"
CROWDGIS_GITHUB_REPO=
# Fine-grained PAT, scoped to that repo, permission "Issues: Read and write"
CROWDGIS_GITHUB_TOKEN=

# Semester access code students enter in the form, e.g. "GIS-HS26"
CROWDGIS_COURSE_CODE=
# Mail suffix students must use (default zhaw.ch; matches students.zhaw.ch too)
CROWDGIS_MAIL_SUFFIX=zhaw.ch
# Max simultaneously open requests per student (default 3)
CROWDGIS_MAX_OPEN_PER_STUDENT=3

# Public base URL of the deployed app, e.g. "https://crowdgis.vercel.app"
CROWDGIS_APP_BASE_URL=

# Secret configured in the GitHub webhook (Settings → Webhooks)
CROWDGIS_WEBHOOK_SECRET=

# Outbound mail — primary provider: AgentMail (agentmail.to)
AGENTMAIL_API_KEY=
# Inbox id of the sender inbox, e.g. "crowdgis@agentmail.to"
CROWDGIS_MAIL_INBOX_ID=

# Outbound mail — SMTP fallback (used only when AGENTMAIL_API_KEY is unset)
CROWDGIS_SMTP_HOST=
CROWDGIS_SMTP_PORT=587
CROWDGIS_SMTP_USER=
CROWDGIS_SMTP_PASS=
CROWDGIS_SMTP_FROM="CrowdGIS <no-reply@example.com>"

# Upstash Redis (added automatically by the Vercel Marketplace integration,
# which uses the KV_REST_API_* names; UPSTASH_* works as fallback)
KV_REST_API_URL=
KV_REST_API_TOKEN=
